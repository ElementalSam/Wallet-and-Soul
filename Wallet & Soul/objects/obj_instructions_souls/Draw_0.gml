draw_set_halign(fa_center);
draw_set_valign(fa_middle);

draw_set_font(fnt_title);
draw_text(x, y - 225, "Souls");

draw_set_font(fnt_menu);
draw_text(x, y + 25, "Souls are the currency of this game.\nSouls can be found in all levels.\nThere are four colors: blue, green, red, and yellow.\nRegions have more souls of certain colors:\nTundra: blue Forest: green\nVolcano: red Desert: yellow");

draw_set_halign(fa_left);
draw_set_valign(fa_top);
