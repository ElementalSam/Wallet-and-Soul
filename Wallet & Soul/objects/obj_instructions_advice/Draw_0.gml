draw_set_halign(fa_center);
draw_set_valign(fa_middle);

draw_set_font(fnt_title);
draw_text(x, y - 225, "Advice");

draw_set_font(fnt_menu);
draw_text(x, y + 25, "You start with souls to buy a basic weapon (green) or\nwallet, so go back and buy before you start playing!\nStay on levels 1 & 2 until you buy a rare (blue) weapon.\nWatch out, dying costs you souls based on your wallet!\nYou are immune to damage while dashing!");

draw_set_halign(fa_left);
draw_set_valign(fa_top);
